{
  "name": "qrspi-agent",
  "version": "1.0.0",
  "description": "QRSPI Agent — structured programming agent workflow framework",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/qrspi",
    "test": "npm test --workspace=packages/qrspi",
    "lint": "npm run lint --workspace=packages/qrspi",
    "qrspi": "npm run build && node packages/qrspi/dist/cli/main.js"
  },
  "keywords": [
    "qrspi",
    "crispy",
    "ai-agent",
    "workflow",
    "cli"
  ],
  "author": "Brian Xie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nixihz/qrspi-agent.git"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
