{
  "name": "qrspi-agent",
  "version": "1.0.0",
  "description": "Structured programming agent workflow CLI for Node.js and TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "qrspi": "dist/cli/main.js"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "qrspi",
    "crispy",
    "ai-agent",
    "workflow",
    "cli",
    "code-generation"
  ],
  "author": "Brian Xie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nixihz/qrspi-agent.git",
    "directory": "packages/qrspi"
  },
  "bugs": {
    "url": "https://github.com/nixihz/qrspi-agent/issues"
  },
  "homepage": "https://github.com/nixihz/qrspi-agent#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
